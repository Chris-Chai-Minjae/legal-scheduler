<%# @TASK P2-S2-T1 - Blog post writing main view %>
<%# @SPEC Blog AI Dashboard - 2-column layout with prompt form + document upload %>

<% content_for :title, "새 글 작성 - Blog AI" %>

<!-- Blog Header -->
<div class="blog-header">
  <h1>✍️ 새 글 작성</h1>
  <div class="blog-header-actions">
    <%= link_to "← 목록으로", blog_posts_path, class: "btn btn-secondary" %>
  </div>
</div>

<!-- Two Column Layout -->
<div class="blog-post-layout" style="display: grid; grid-template-columns: 70% 30%; gap: 24px; align-items: start;">

  <!-- Left Column: Prompt Form -->
  <div>
    <div class="blog-prompt-form">
      <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 20px; color: var(--gray-900);">
        📝 글 작성 설정
      </h2>

      <%= form_with model: @post, url: blog_posts_path, id: "post_form", data: { turbo: false } do |f| %>
        <!-- Prompt -->
        <div class="form-group" style="margin-bottom: 24px;">
          <label class="label" style="display: block; font-weight: 500; margin-bottom: 8px; color: var(--gray-700);">
            글 주제 <span style="color: var(--danger);">*</span>
          </label>
          <%= f.text_area :prompt,
              class: "blog-prompt-textarea",
              placeholder: "어떤 주제로 글을 작성할까요?\n예: 변호사의 AI 활용법에 대해 작성해주세요",
              rows: 4,
              required: true,
              style: "margin-bottom: 8px;" %>
          <div style="font-size: 12px; color: var(--gray-500);">
            💡 구체적으로 작성할수록 더 좋은 결과를 얻을 수 있습니다.
          </div>
        </div>

        <!-- Tone Selector -->
        <div class="form-group" style="margin-bottom: 24px;">
          <label class="label" style="display: block; font-weight: 500; margin-bottom: 12px; color: var(--gray-700);">
            글 톤
          </label>
          <div class="blog-tone-selector">
            <div class="blog-tone-option">
              <%= f.radio_button :tone, "professional", checked: true, id: "tone_professional" %>
              <%= label_tag "tone_professional", "🎯 전문적", class: "blog-tone-label" %>
            </div>
            <div class="blog-tone-option">
              <%= f.radio_button :tone, "easy", id: "tone_easy" %>
              <%= label_tag "tone_easy", "😊 쉬운", class: "blog-tone-label" %>
            </div>
            <div class="blog-tone-option">
              <%= f.radio_button :tone, "storytelling", id: "tone_storytelling" %>
              <%= label_tag "tone_storytelling", "📖 스토리텔링", class: "blog-tone-label" %>
            </div>
          </div>
        </div>

        <!-- Length Selector -->
        <div class="form-group" style="margin-bottom: 24px;">
          <label class="label" style="display: block; font-weight: 500; margin-bottom: 12px; color: var(--gray-700);">
            글 길이
          </label>
          <div class="blog-length-selector">
            <div class="blog-length-option">
              <%= f.radio_button :length_setting, "short", id: "length_short" %>
              <%= label_tag "length_short", "짧은 (1,500자)", class: "blog-length-label" %>
            </div>
            <div class="blog-length-option">
              <%= f.radio_button :length_setting, "medium", checked: true, id: "length_medium" %>
              <%= label_tag "length_medium", "보통 (2,500자)", class: "blog-length-label" %>
            </div>
            <div class="blog-length-option">
              <%= f.radio_button :length_setting, "long", id: "length_long" %>
              <%= label_tag "length_long", "긴 (4,500자)", class: "blog-length-label" %>
            </div>
          </div>
        </div>

        <!-- Title (Optional) -->
        <div class="form-group" style="margin-bottom: 24px;">
          <label class="label" style="display: block; font-weight: 500; margin-bottom: 8px; color: var(--gray-700);">
            제목 (선택사항)
          </label>
          <%= f.text_field :title,
              class: "input",
              placeholder: "제목을 직접 입력하거나 비워두면 AI가 생성합니다" %>
          <div style="font-size: 12px; color: var(--gray-500); margin-top: 4px;">
            ℹ️ 비워두면 AI가 자동으로 제목을 생성합니다.
          </div>
        </div>

        <!-- Image Category Selector -->
        <div class="form-group" style="margin-bottom: 24px;">
          <label class="label" style="display: block; font-weight: 500; margin-bottom: 12px; color: var(--gray-700);">
            🏷️ 이미지 카테고리
            <span style="font-size: 12px; color: var(--gray-500); font-weight: 400;">
              — 본문과 함께 자동 삽입될 상징 이미지의 주제 분야
            </span>
          </label>

          <!-- 기본: 자동 감지 + 사용 안 함 -->
          <div class="image-preset-grid image-preset-grid--primary" role="radiogroup" aria-label="이미지 스타일 선택 (기본)">
            <label class="image-preset-option">
              <input type="radio" name="blog_post[image_preset]" value="auto" checked>
              <div class="image-preset-card">
                <div class="ipc-icon" aria-hidden="true">🎨</div>
                <div class="ipc-label">자동</div>
                <div class="ipc-sub">본문 주제 감지 (권장)</div>
              </div>
            </label>
            <label class="image-preset-option">
              <input type="radio" name="blog_post[image_preset]" value="none">
              <div class="image-preset-card">
                <div class="ipc-icon" aria-hidden="true">🚫</div>
                <div class="ipc-label">사용 안 함</div>
                <div class="ipc-sub">텍스트만</div>
              </div>
            </label>
          </div>

          <!-- 고급: 카테고리 수동 지정 (접을 수 있음) -->
          <details class="image-preset-advanced" style="margin-top: 12px;">
            <summary style="cursor: pointer; font-size: 13px; color: var(--gray-600); padding: 6px 0;">
              ⚙️ 카테고리 수동 지정 (9종)
            </summary>
            <div class="image-preset-grid image-preset-grid--secondary" role="radiogroup" aria-label="이미지 카테고리 수동 지정" style="margin-top: 10px;">
              <!-- 기본 5종 -->
              <label class="image-preset-option">
                <input type="radio" name="blog_post[image_preset]" value="justice">
                <div class="image-preset-card">
                  <div class="ipc-icon" aria-hidden="true">⚖️</div>
                  <div class="ipc-label">사법상징</div>
                  <div class="ipc-sub">저울·법봉</div>
                </div>
              </label>
              <label class="image-preset-option">
                <input type="radio" name="blog_post[image_preset]" value="documents">
                <div class="image-preset-card">
                  <div class="ipc-icon" aria-hidden="true">📜</div>
                  <div class="ipc-label">법률문서</div>
                  <div class="ipc-sub">판결문·관인</div>
                </div>
              </label>
              <label class="image-preset-option">
                <input type="radio" name="blog_post[image_preset]" value="courthouse">
                <div class="image-preset-card">
                  <div class="ipc-icon" aria-hidden="true">🏛️</div>
                  <div class="ipc-label">법원건물</div>
                  <div class="ipc-sub">외관</div>
                </div>
              </label>
              <label class="image-preset-option">
                <input type="radio" name="blog_post[image_preset]" value="abstract">
                <div class="image-preset-card">
                  <div class="ipc-icon" aria-hidden="true">✨</div>
                  <div class="ipc-label">추상상징</div>
                  <div class="ipc-sub">회복·희망</div>
                </div>
              </label>
              <label class="image-preset-option">
                <input type="radio" name="blog_post[image_preset]" value="library">
                <div class="image-preset-card">
                  <div class="ipc-icon" aria-hidden="true">📚</div>
                  <div class="ipc-label">법률서재</div>
                  <div class="ipc-sub">법전·도서관</div>
                </div>
              </label>
              <!-- 신규 4종: 주제별 맥락 이미지 -->
              <label class="image-preset-option">
                <input type="radio" name="blog_post[image_preset]" value="traffic">
                <div class="image-preset-card">
                  <div class="ipc-icon" aria-hidden="true">🚗</div>
                  <div class="ipc-label">교통</div>
                  <div class="ipc-sub">음주운전·사고</div>
                </div>
              </label>
              <label class="image-preset-option">
                <input type="radio" name="blog_post[image_preset]" value="finance">
                <div class="image-preset-card">
                  <div class="ipc-icon" aria-hidden="true">💰</div>
                  <div class="ipc-label">금융</div>
                  <div class="ipc-sub">사기·횡령</div>
                </div>
              </label>
              <label class="image-preset-option">
                <input type="radio" name="blog_post[image_preset]" value="corporate">
                <div class="image-preset-card">
                  <div class="ipc-icon" aria-hidden="true">🏢</div>
                  <div class="ipc-label">직장</div>
                  <div class="ipc-sub">부당해고·노동</div>
                </div>
              </label>
              <label class="image-preset-option">
                <input type="radio" name="blog_post[image_preset]" value="property">
                <div class="image-preset-card">
                  <div class="ipc-icon" aria-hidden="true">🏘️</div>
                  <div class="ipc-label">부동산</div>
                  <div class="ipc-sub">임대차·매매</div>
                </div>
              </label>
            </div>
            <div style="font-size: 11px; color: var(--gray-500); margin-top: 8px;">
              ℹ️ "자동" 은 본문 주제에서 가장 적합한 카테고리를 자동으로 선택합니다.
              수동 지정은 특정 카테고리를 강제하고 싶을 때만 사용하세요.
            </div>
          </details>

          <div style="font-size: 12px; color: var(--gray-500); margin-top: 10px;">
            💡 성범죄 피해자 변호사 블로그 윤리 기준에 따라 인물·재연·선정성 이미지는 자동 차단됩니다.
          </div>
        </div>

        <!-- Image Count Selector -->
        <div class="form-group" style="margin-bottom: 24px;">
          <label class="label" style="display: block; font-weight: 500; margin-bottom: 12px; color: var(--gray-700);">
            이미지 개수
          </label>
          <div class="image-count-grid" role="radiogroup" aria-label="이미지 개수 선택">
            <label class="image-preset-option">
              <input type="radio" name="blog_post[image_count]" value="1">
              <div class="image-preset-card compact">
                <div class="ipc-label">1장</div>
              </div>
            </label>
            <label class="image-preset-option">
              <input type="radio" name="blog_post[image_count]" value="2" checked>
              <div class="image-preset-card compact">
                <div class="ipc-label">2장</div>
                <div class="ipc-sub">권장</div>
              </div>
            </label>
            <label class="image-preset-option">
              <input type="radio" name="blog_post[image_count]" value="3">
              <div class="image-preset-card compact">
                <div class="ipc-label">3장</div>
              </div>
            </label>
          </div>
          <div style="font-size: 12px; color: var(--gray-500); margin-top: 8px;">
            ⏱️ 이미지 1장당 약 50~70초 소요됩니다.
          </div>
        </div>

        <!-- Image Style (Visual Type) Selector -->
        <div class="form-group" style="margin-bottom: 24px;">
          <label class="label" style="display: block; font-weight: 500; margin-bottom: 12px; color: var(--gray-700);">
            🎭 이미지 유형
            <span style="font-size: 12px; color: var(--gray-500); font-weight: 400;">
              — 이미지의 시각적 표현 방식
            </span>
          </label>

          <div class="image-style-grid" role="radiogroup" aria-label="이미지 유형 선택">
            <label class="image-preset-option">
              <input type="radio" name="blog_post[image_style]" value="auto" checked>
              <div class="image-preset-card">
                <div class="ipc-icon" aria-hidden="true">🎨</div>
                <div class="ipc-label">자동</div>
                <div class="ipc-sub">LLM이 최적 선택 (권장)</div>
              </div>
            </label>
            <label class="image-preset-option">
              <input type="radio" name="blog_post[image_style]" value="symbol">
              <div class="image-preset-card">
                <div class="ipc-icon" aria-hidden="true">⚖️</div>
                <div class="ipc-label">순수 상징</div>
                <div class="ipc-sub">저울·법봉·추상</div>
              </div>
            </label>
            <label class="image-preset-option">
              <input type="radio" name="blog_post[image_style]" value="infographic">
              <div class="image-preset-card">
                <div class="ipc-icon" aria-hidden="true">📊</div>
                <div class="ipc-label">인포그래픽</div>
                <div class="ipc-sub">플로우차트·비교표</div>
              </div>
            </label>
            <label class="image-preset-option">
              <input type="radio" name="blog_post[image_style]" value="code_card">
              <div class="image-preset-card">
                <div class="ipc-icon" aria-hidden="true">📋</div>
                <div class="ipc-label">법조문 카드</div>
                <div class="ipc-sub">조문·항목 시각화</div>
              </div>
            </label>
            <label class="image-preset-option">
              <input type="radio" name="blog_post[image_style]" value="process_icon">
              <div class="image-preset-card">
                <div class="ipc-icon" aria-hidden="true">🔄</div>
                <div class="ipc-label">프로세스</div>
                <div class="ipc-sub">단계·흐름 아이콘</div>
              </div>
            </label>
          </div>
          <div style="font-size: 12px; color: var(--gray-500); margin-top: 8px;">
            ℹ️ "자동"은 본문 내용을 분석하여 가장 적합한 유형을 선택합니다.
          </div>
        </div>

        <!-- Submit Button -->
        <%= button_tag type: "submit", class: "btn btn-primary", style: "width: 100%;" do %>
          ✨ AI로 작성하기
        <% end %>
      <% end %>
    </div>

    <!-- Streaming Output Area (Initially Hidden) -->
    <div id="streaming-output" style="display: none; margin-top: 24px;"
         data-controller="streaming"
         data-streaming-url-value="">
      <div class="blog-editor">
        <h2 data-streaming-target="title"
            class="blog-editor-title"
            contenteditable="true"
            style="margin-bottom: 24px;"></h2>
        <div data-streaming-target="output"
             class="blog-editor-content"
             style="white-space: pre-wrap;"></div>
        <span data-streaming-target="cursor"
              class="streaming-cursor"
              style="display: none;"></span>
      </div>

      <div class="blog-header-actions" style="margin-top: 24px; justify-content: flex-start;">
        <%= button_tag "📋 복사",
            type: "button",
            class: "btn btn-secondary",
            data: { action: "click->streaming#copy" } %>
        <%= button_tag "🔄 재생성",
            type: "button",
            class: "btn btn-secondary",
            data: { action: "click->streaming#regenerate" } %>
        <%= link_to "💾 저장 완료",
            "#",
            class: "btn btn-primary",
            data: { streaming_target: "saveLink" },
            style: "margin-left: auto;" %>
      </div>
    </div>
  </div>

  <!-- Right Column: Reference Documents Upload -->
  <div>
    <div class="blog-prompt-form" data-controller="file-upload">
      <h3 style="font-size: 16px; font-weight: 600; margin-bottom: 16px; color: var(--gray-900);">
        📄 참고 문서
      </h3>

      <%= form_with url: blog_documents_path,
          method: :post,
          data: { file_upload_target: "form" },
          multipart: true do |f| %>

        <!-- Dropzone -->
        <div class="file-dropzone"
             data-file-upload-target="dropzone"
             data-action="dragover->file-upload#dragover dragleave->file-upload#dragleave drop->file-upload#drop click->file-upload#click">
          <div class="file-dropzone-icon">📁</div>
          <div class="file-dropzone-text">파일을 끌어다 놓으세요</div>
          <div class="file-dropzone-hint">또는 클릭하여 선택</div>
          <div class="file-dropzone-hint" style="margin-top: 8px;">
            PDF, DOCX, HWP (최대 50MB)
          </div>
        </div>

        <!-- Hidden File Input -->
        <%= f.file_field :file,
            accept: ".pdf,.docx,.hwp",
            data: {
              file_upload_target: "input",
              action: "change->file-upload#select"
            },
            style: "display: none;" %>

        <!-- Tag Selector -->
        <div style="margin-top: 16px;">
          <label class="label" style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 8px; color: var(--gray-700);">
            태그
          </label>
          <%= f.select :tag,
              options_for_select([
                ["태그 없음", ""],
                ["판례", "판례"],
                ["법령", "법령"],
                ["논문", "논문"],
                ["기타", "기타"]
              ]),
              {},
              class: "select" %>
        </div>

        <!-- File Preview Area -->
        <div class="file-preview" data-file-upload-target="preview"></div>

        <!-- Info Box -->
        <div class="info-box" style="margin-top: 16px;">
          <div class="info-icon">💡</div>
          <div class="info-text">
            업로드한 문서는 AI가 참고하여 더 전문적인 내용을 작성합니다.
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  // Form submission: Save post then redirect to show page where streaming auto-starts
  document.getElementById('post_form').addEventListener('submit', async (e) => {
    e.preventDefault()

    const form = e.target
    const formData = new FormData(form)
    const submitButton = form.querySelector('button[type="submit"]')

    submitButton.disabled = true
    submitButton.innerHTML = '⏳ 저장 중...'

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'Accept': 'application/json'
        }
      })

      if (response.ok) {
        const data = await response.json()
        // Redirect to show page — auto-streaming will start there
        window.location.href = data.redirect_url || `/blog/posts/${data.id}`
      } else {
        throw new Error('생성 실패')
      }
    } catch (error) {
      console.error('Error:', error)
      alert('❌ 글 생성 중 오류가 발생했습니다. 다시 시도해주세요.')
      submitButton.disabled = false
      submitButton.innerHTML = '✨ AI로 작성하기'
    }
  })

  // :has() 미지원 브라우저 fallback (Firefox < 121)
  if (!CSS.supports('selector(:has(*))')) {
    document.querySelectorAll('.image-preset-option input[type="radio"]').forEach(radio => {
      radio.addEventListener('change', () => {
        radio.closest('.image-preset-grid, .image-count-grid, .image-style-grid')
          .querySelectorAll('.image-preset-option').forEach(opt => opt.classList.remove('selected'));
        radio.closest('.image-preset-option').classList.add('selected');
      });
      if (radio.checked) radio.closest('.image-preset-option').classList.add('selected');
    });
  }
</script>

<style>
  /* Form Group */
  .form-group {
    margin-bottom: 24px;
  }

  .label {
    display: block;
    font-weight: 500;
    margin-bottom: 8px;
    color: var(--gray-700);
    font-size: 14px;
  }

  /* ─── Image Preset / Count Grid (통일된 카드 디자인) ─── */
  .image-preset-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 10px;
  }

  /* 기본 영역 (자동 + 사용 안 함) — 2 컬럼 */
  .image-preset-grid--primary {
    grid-template-columns: repeat(2, 1fr);
    max-width: 420px;
  }

  /* 고급 영역 (9개 카테고리) — 최대 너비 내 auto-fill */
  .image-preset-grid--secondary {
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  }

  .image-preset-advanced summary::-webkit-details-marker { display: none; }
  .image-preset-advanced summary {
    list-style: none;
    user-select: none;
  }
  .image-preset-advanced summary:hover {
    color: var(--gray-800) !important;
  }
  .image-preset-advanced[open] summary {
    color: var(--gray-800) !important;
    font-weight: 500;
  }

  .image-count-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    max-width: 420px;
  }

  .image-style-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    max-width: 720px;
  }

  .image-preset-option {
    display: block;
    cursor: pointer;
    margin: 0;
  }

  .image-preset-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .image-preset-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 14px 8px;
    min-height: 92px;
